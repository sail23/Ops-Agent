## 四、Prometheus 工具定义

### 4.1 prometheus_query

查询单个时间点的指标值。

```json
{
  "name": "prometheus_query",
  "description": "执行 PromQL 查询，返回指标值",
  "parameters": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "PromQL 查询语句",
        "examples": [
          "rate(http_requests_total{status='500'}[5m])",
          "node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes * 100"
        ]
      },
      "time": {
        "type": "string",
        "description": "查询时间点（ISO 8601 或 Unix 时间戳），默认为当前时间"
      }
    },
    "required": ["query"]
  }
}
```

**返回示例**：
```json
{
  "status": "success",
  "data": [
    {
      "metric": {
        "instance": "server-01:9100",
        "job": "node_exporter"
      },
      "value": [1700000000, "85.5"]
    }
  ]
}
```

### 4.2 prometheus_query_range

查询时间范围内的指标值。

```json
{
  "name": "prometheus_query_range",
  "description": "执行范围 PromQL 查询，返回时间序列数据",
  "parameters": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "PromQL 查询语句"
      },
      "start": {
        "type": "string",
        "description": "开始时间（ISO 8601 或 Unix 时间戳）"
      },
      "end": {
        "type": "string",
        "description": "结束时间（ISO 8601 或 Unix 时间戳）"
      },
      "step": {
        "type": "string",
        "description": "采样间隔（如 '1m', '5m', '1h'）",
        "default": "1m"
      }
    },
    "required": ["query", "start", "end"]
  }
}
```

### 4.3 prometheus_alerts

查询当前告警状态。

```json
{
  "name": "prometheus_alerts",
  "description": "查询 Prometheus 告警状态",
  "parameters": {
    "type": "object",
    "properties": {
      "alert_state": {
        "type": "string",
        "description": "告警状态筛选",
        "enum": ["firing", "pending", "inactive"],
        "default": "firing"
      },
      "alert_name": {
        "type": "string",
        "description": "告警名称筛选（可选）"
      }
    }
  }
}
```

**返回示例**：
```json
{
  "alerts": [
    {
      "name": "HighCPUUsage",
      "state": "firing",
      "severity": "critical",
      "labels": {
        "instance": "server-01",
        "job": "node_exporter"
      },
      "annotations": {
        "summary": "CPU 使用率超过 90%",
        "description": "server-01 CPU 当前使用率: 95%"
      },
      "startsAt": "2024-01-15T10:00:00Z"
    }
  ]
}
```

### 4.4 metrics_summary

根据指标类型自动生成诊断 PromQL。

```json
{
  "name": "metrics_summary",
  "description": "生成指定指标的诊断 PromQL",
  "parameters": {
    "type": "object",
    "properties": {
      "metric_type": {
        "type": "string",
        "description": "指标类型",
        "enum": ["cpu", "memory", "disk", "network", "http", "database"]
      },
      "instance": {
        "type": "string",
        "description": "实例名称（如 'server-01:9100'）"
      },
      "time_range": {
        "type": "string",
        "description": "时间范围",
        "default": "5m"
      }
    },
    "required": ["metric_type"]
  }
}
```

**自动生成 PromQL 示例**：

| metric_type | 生成的 PromQL |
|-------------|--------------|
| cpu | `100 - (avg by (instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100)` |
| memory | `(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100` |
| disk | `100 - (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"} * 100)` |
| network | `rate(node_network_receive_bytes_total[5m])` |
| http | `rate(http_requests_total{status=~"5.."}[5m])` |
| database | `rate(postgresql_database_stat_numbackends[5m])` |

