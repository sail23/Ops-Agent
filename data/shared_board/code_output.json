"from neo4j import GraphDatabase\nimport pandas as pd\nfrom datetime import datetime, timedelta\nimport json\nfrom collections import Counter, defaultdict\n\n# Neo4j连接配置\nNEO4J_URI = \"bolt://localhost:7687\"\nNEO4J_USER = \"neo4j\"\nNEO4J_PASSWORD = \"password\"\n\nclass RootCauseAnalyzer:\n    def __init__(self, uri, user, password):\n        self.driver = GraphDatabase.driver(uri, auth=(user, password))\n        \n    def close(self):\n        self.driver.close()\n        \n    def query_error_trace(self, trace_id):\n        \"\"\"查询指定trace的完整调用链\"\"\"\n        with self.driver.session() as session:\n            result = session.run(\n                \"\"\"\n                MATCH (t:Trace {trace_id: $trace_id})\n                OPTIONAL MATCH path = (t)-[:CONTAINS]->(s:Span)\n                OPTIONAL MATCH (s)-[:CALLS]->(next:Span)\n                WITH t, collect(DISTINCT s) as spans, collect(DISTINCT next) as next_spans\n                RETURN t.trace_id as trace_id, \n                       t.start_time as start_time,\n                       t.end_time as end_time,\n                       t.duration as duration,\n                       [s in spans | {span_id: s.span_id, service: s.service_name, \n                                     operation: s.operation_name, duration: s.duration,\n                                     status: s.status, error: s.error_message}] as spans\n                \"\"\",\n                trace_id=trace_id\n            )\n            return result.single()\n            \n    def query_similar_cases(self, trace_id):\n        \"\"\"查找相似的历史故障案例\"\"\"\n        with self.driver.session() as session:\n            # 使用Graph RAG查找相似案例\n            result = session.run(\n                \"\"\"\n                // 查找当前trace涉及的services\n                MATCH (t:Trace {trace_id: $trace_id})-[:CONTAINS]->(s:Span)\n                WITH collect(DISTINCT s.service_name) as services\n                \n                // 查找包含相同服务的历史故障trace\n                MATCH (hist_t:Trace)\n                WHERE hist_t.trace_id <> $trace_id \n                  AND hist_t.status IN ['error', 'warning', 'slow']\n                MATCH (hist_t)-[:CONTAINS]->(hist_s:Span)\n                WHERE hist_s.service_name IN services\n                \n                // 计算相似度\n                WITH hist_t, \n                     collect(DISTINCT hist_s.service_name) as matched_services,\n                     size(services) as total_services\n                WHERE size(matched_services) / total_services >= 0.3\n                \n                RETURN hist_t.trace_id as case_id,\n                       hist_t.incident_id as incident_id,\n                       hist_t.summary as summary,\n                       hist_t.start_time as start_time,\n                       matched_services,\n                       size(matched_services) * 1.0 / total_services as similarity_score\n                ORDER BY similarity_score DESC\n                LIMIT 10\n                \"\"\",\n                trace_id=trace_id\n            )\n            return [record for record in result]\n            \n    def query_slow_spans(self, trace_id, threshold_ms=5000):\n        \"\"\"查询执行时间超过阈值的span\"\"\"\n        with self.driver.session() as session:\n            result = session.run(\n                \"\"\"\n                MATCH (t:Trace {trace_id: $trace_id})-[:CONTAINS]->(s:Span)\n                WHERE s.duration > $threshold\n                RETURN s.span_id as span_id,\n                       s.service_name as service,\n                       s.operation_name as operation,\n                       s.duration as duration,\n                       s.start_time as start_time,\n                       s.end_time as end_time\n                ORDER BY s.duration DESC\n                \"\"\",\n                trace_id=trace_id,\n                threshold=threshold_ms\n            )\n            return [record for record in result]\n            \n    def query_error_spans(self, trace_id):\n        \"\"\"查询包含错误的span\"\"\"\n        with self.driver.session() as session:\n            result = session.run(\n                \"\"\"\n                MATCH (t:Trace {trace_id: $trace_id})-[:CONTAINS]->(s:Span)\n                WHERE s.status = 'ERROR' OR s.error_message IS NOT NULL\n                RETURN s.span_id as span_id,\n                       s.service_name as service,\n                       s.operation_name as operation,\n                       s.error_message as error_message,\n                       s.duration as duration,\n                       s.start_time as start_time\n                ORDER BY s.start_time ASC\n                \"\"\",\n                trace_id=trace_id\n            )\n            return [record for record in result]\n            \n    def query_fault_propagation(self, trace_id):\n        \"\"\"分析故障传播路径\"\"\"\n        with self.driver.session() as session:\n            result = session.run(\n                \"\"\"\n                // 查找调用链和故障传播关系\n                MATCH (t:Trace {trace_id: $trace_id})-[:CONTAINS]->(s1:Span)\n                MATCH (s1)-[:CALLS]->(s2:Span)\n                WHERE s1.status = 'ERROR' OR s2.status = 'ERROR' \n                   OR s1.duration > 5000 OR s2.duration > 5000\n                \n                RETURN s1.service_name as source_service,\n                       s1.operation_name as source_operation,\n                       s1.duration as source_duration,\n                       s1.status as source_status,\n                       s2.service_name as target_service,\n                       s2.operation_name as target_operation,\n                       s2.duration as target_duration,\n                       s2.status as target_status,\n                       s1.start_time as call_time\n                ORDER BY call_time ASC\n                \"\"\",\n                trace_id=trace_id\n            )\n            return [record for record in result]\n            \n    def analyze_service_dependencies(self, trace_id):\n        \"\"\"分析服务依赖关系和调用频率\"\"\"\n        with self.driver.session() as session:\n            result = session.run(\n                \"\"\"\n                MATCH (t:Trace {trace_id: $trace_id})-[:CONTAINS]->(s1:Span)\n                OPTIONAL MATCH (s1)-[:CALLS]->(s2:Span)\n                WITH s1.service_name as service, \n                     s2.service_name as dependency,\n                     count(*) as call_count,\n                     avg(s2.duration) as avg_duration,\n                     max(s2.duration) as max_duration\n                WHERE dependency IS NOT NULL\n                RETURN service, \n                       dependency,\n                       call_count,\n                       round(avg_duration, 2) as avg_duration_ms,\n                       max_duration as max_duration_ms\n                ORDER BY call_count DESC, avg_duration DESC\n                \"\"\",\n                trace_id=trace_id\n            )\n            return [record for record in result]\n\ndef format_output(title, data, data_type=\"list\"):\n    \"\"\"格式化输出结果\"\"\"\n    print(f\"\\n{'='*80}\")\n    print(f\"📊 {title}\")\n    print(f\"{'='*80}\")\n    \n    if not data:\n        print(\"  无数据\")\n        return\n        \n    if data_type == \"list\" and isinstance(data, list):\n        for i, item in enumerate(data, 1):\n            print(f\"\\n  [{i}] {'-'*50}\")\n            if isinstance(item, dict):\n                for key, value in item.items():\n                    print(f\"      {key}: {value}\")\n            else:\n                print(f\"      {item}\")\n    elif data_type == \"record\" and isinstance(data, dict):\n        for key, value in data.items():\n            if key == \"spans\" and isinstance(value, list):\n                print(f\"  Spans数量: {len(value)}\")\n                for span in value:\n                    print(f\"    - {span}\")\n            else:\n                print(f\"  {key}: {value}\")\n\ndef main():\n    trace_id = \"trace-c982406d8f354a31b5e656ac1f82cb7a\"\n    \n    analyzer = RootCauseAnalyzer(NEO4J_URI, NEO4J_USER, NEO4J_PASSWORD)\n    \n    try:\n        # 1. 查询完整trace信息\n        print(\"\\n🔍 正在分析trace: \", trace_id)\n        trace_data = analyzer.query_error_trace(trace_id)\n        if trace_data:\n            format_output(\"完整Trace信息\", dict(trace_data), \"record\")\n            \n        # 2. 查询错误span\n        error_spans = analyzer.query_error_spans(trace_id)\n        format_output(\"错误Span详情\", [dict(s) for s in error_spans])\n        \n        # 3. 查询慢span（>5秒）\n        slow_spans = analyzer.query_slow_spans(trace_id, 5000)  # 5秒阈值\n        format_output(f\"慢Span详情 (>5秒, 共{len(slow_spans)}个)\", [dict(s) for s in slow_spans])\n        \n        # 4. 查询故障传播路径\n        fault_paths = analyzer.query_fault_propagation(trace_id)\n        format_output(\"故障传播路径分析\", [dict(p) for p in fault_paths])\n        \n        # 5. 查询相似历史案例\n        similar_cases = analyzer.query_similar_cases(trace_id)\n        format_output(f\"相似历史故障案例 (共{len(similar_cases)}个)\", [dict(c) for c in similar_cases])\n        \n        # 6. 服务依赖分析\n        dependencies = analyzer.analyze_service_dependencies(trace_id)\n        format_output(\"服务依赖关系分析\", [dict(d) for d in dependencies])\n        \n        # 7. 综合根因分析\n        print(\"\\n\" + \"=\"*80)\n        print(\"📋 综合根因分析结果\")\n        print(\"=\"*80)\n        \n        # 分析根因\n        root_causes = []\n        \n        # 如果有错误span，优先分析\n        if error_spans:\n            for span in error_spans:\n                root_causes.append({\n                    \"根因类型\": \"ERROR\",\n                    \"根因服务\": span[\"service\"],\n                    \"根因操作\": span[\"operation\"],\n                    \"错误信息\": span.get(\"error_message\", \"无详细错误信息\"),\n                    \"置信度\": \"高\",\n                    \"分析\": \"该服务直接返回错误，极可能是根因\"\n                })\n        \n        # 分析慢span\n        if slow_spans and not error_spans:\n            avg_slow_duration = sum(s[\"duration\"] for s in slow_spans) / len(slow_spans)\n            worst_span = max(slow_spans, key=lambda x: x[\"duration\"])\n            root_causes.append({\n                \"根因类型\": \"SLOW\",\n                \"根因服务\": worst_span[\"service\"],\n                \"根因操作\": worst_span[\"operation\"],\n                \"响应时间\": f\"{worst_span['duration']}ms (平均: {avg_slow_duration:.0f}ms)\",\n                \"置信度\": \"中\",\n                \"分析\": \"服务响应时间严重超时，可能是性能瓶颈或依赖服务慢\"\n            })\n        \n        # 分析故障传播路径\n        if fault_paths:\n            # 找出最频繁出现的问题源服务\n            source_counts = defaultdict(int)\n            for path in fault_paths:\n                if path[\"source_status\"] == \"ERROR\":\n                    source_counts[path[\"source_service\"]] += 1\n            if source_counts:\n                worst_source = max(source_counts, key=source_counts.get)\n                root_causes.append({\n                    \"根因类型\": \"PROPAGATION\",\n                    \"根因服务\": worst_source,\n                    \"传播路径\": f\"影响{len(fault_paths)}个下游调用\",\n                    \"置信度\": \"中高\",\n                    \"分析\": f\"错误从{worst_source}传播到多个下游服务\"\n                })\n        \n        # 输出根因分析\n        if root_causes:\n            for i, rc in enumerate(root_causes, 1):\n                print(f\"\\n  根因分析 [{i}]:\")\n                for key, value in rc.items():\n                    print(f\"    {key}: {value}\")\n        else:\n            print(\"\\n  未发现明显异常，可能需要进一步分析\")\n            \n        # 输出建议\n        print(\"\\n\" + \"=\"*80)\n        print(\"💡 建议措施\")\n        print(\"=\"*80)\n        suggestions = set()\n        \n        for rc in root_causes:\n            if rc[\"根因类型\"] == \"ERROR\":\n                suggestions.add(f\"1. 立即检查{rc['根因服务']}的日志和错误堆栈\")\n                suggestions.add(f\"2. 排查{rc['根因服务']}的依赖服务是否正常\")\n            elif rc[\"根因类型\"] == \"SLOW\":\n                suggestions.add(f\"1. 分析{rc['根因服务']}的性能瓶颈，检查资源使用情况\")\n                suggestions.add(\"2. 考虑增加缓存或优化查询\")\n            elif rc[\"根因类型\"] == \"PROPAGATION\":\n                suggestions.add(\"1. 实施断路器模式，防止故障级联传播\")\n                suggestions.add(\"2. 加强服务间调用的超时和重试策略\")\n        \n        for s in suggestions:\n            print(f\"  • {s}\")\n        \n    except Exception as e:\n        print(f\"❌ 分析过程出错: {str(e)}\")\n    finally:\n        analyzer.close()\n\nif __name__ == \"__main__\":\n    main()"